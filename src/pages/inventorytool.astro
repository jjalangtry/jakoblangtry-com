---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Inventory Tool | Jakob Langtry"
  description="Shared barcode entry tool for building an inventory CSV."
>
  <main>
    <section>
      <h1>Inventory Tool</h1>
      <p>
        Scan a barcode, type the item, and download the CSV when you are done.
      </p>
      <p>
        <a href="/api/inventory/export.csv">Download CSV</a>
        |
        <a href="/">Back Home</a>
      </p>
    </section>

    <section aria-labelledby="inventory-form-heading">
      <h2 id="inventory-form-heading">Add Item</h2>

      <form id="inventory-form">
        <p>
          <label for="barcode">Barcode</label><br />
          <input
            id="barcode"
            name="barcode"
            type="text"
            inputmode="numeric"
            placeholder="Scan barcode here"
            autocomplete="off"
            autofocus
            required
          />
        </p>

        <p>
          <label for="description">Item</label><br />
          <input
            id="description"
            name="description"
            type="text"
            maxlength="280"
            placeholder="Item name or description"
            autocomplete="off"
            required
          />
        </p>

        <p>
          <button id="submit-button" type="submit">Add item</button>
          <button id="clear-button" type="button">Clear</button>
        </p>

        <p id="form-status" role="status" aria-live="polite"></p>
      </form>
    </section>

    <section aria-labelledby="inventory-feed-heading">
      <h2 id="inventory-feed-heading">Recent Scans</h2>
      <p id="inventory-count">Loading...</p>
      <p id="inventory-path"></p>
      <div id="inventory-feed"></div>
    </section>

    <style>
      main {
        max-width: 760px;
        margin: 32px auto;
        padding: 0 16px 32px;
        font-family:
          system-ui,
          -apple-system,
          BlinkMacSystemFont,
          "Segoe UI",
          sans-serif;
      }

      section {
        margin-bottom: 24px;
      }

      input {
        width: 100%;
        max-width: 420px;
        padding: 8px;
        font: inherit;
      }

      button {
        padding: 8px 12px;
        font: inherit;
      }

      table {
        width: 100%;
        border-collapse: collapse;
      }

      th,
      td {
        border: 1px solid #cccccc;
        padding: 8px;
        text-align: left;
        vertical-align: top;
      }

      #form-status {
        min-height: 1.5em;
      }
    </style>
  </main>

  <script>
    const form = document.getElementById("inventory-form");
    const barcodeInput = document.getElementById("barcode");
    const descriptionInput = document.getElementById("description");
    const statusEl = document.getElementById("form-status");
    const countEl = document.getElementById("inventory-count");
    const pathEl = document.getElementById("inventory-path");
    const feedEl = document.getElementById("inventory-feed");
    const clearButton = document.getElementById("clear-button");
    const submitButton = document.getElementById("submit-button");

    function escapeHtml(value) {
      return String(value ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#39;");
    }

    function formatTimestamp(value) {
      const date = new Date(value);
      if (Number.isNaN(date.getTime())) {
        return value;
      }

      return new Intl.DateTimeFormat(undefined, {
        dateStyle: "medium",
        timeStyle: "short",
      }).format(date);
    }

    function renderItems(items) {
      if (!feedEl) return;

      if (!items.length) {
        feedEl.innerHTML =
          '<p class="inventory-empty">No items scanned yet. Your next scan will create the CSV.</p>';
        return;
      }

      feedEl.innerHTML = `
        <table>
          <thead>
            <tr>
              <th>Time</th>
              <th>Barcode</th>
              <th>Item</th>
            </tr>
          </thead>
          <tbody>
            ${items
              .map(
                (item) => `
                  <tr>
                    <td>${escapeHtml(formatTimestamp(item.createdAt))}</td>
                    <td>${escapeHtml(item.barcode)}</td>
                    <td>${escapeHtml(item.description)}</td>
                  </tr>
                `,
              )
              .join("")}
          </tbody>
        </table>
      `;
    }

    async function loadItems() {
      try {
        const response = await fetch("/api/inventory?limit=20", {
          headers: { Accept: "application/json" },
          cache: "no-store",
        });
        if (!response.ok) {
          throw new Error("Unable to load items.");
        }

        const payload = await response.json();
        countEl.textContent = `${payload.count} recent item${payload.count === 1 ? "" : "s"}`;
        pathEl.textContent = payload.csvPath ? `CSV: ${payload.csvPath}` : "";
        renderItems(payload.items || []);
      } catch {
        countEl.textContent = "Recent scans unavailable";
        renderItems([]);
        if (pathEl) pathEl.textContent = "";
      }
    }

    function setStatus(message, kind = "neutral") {
      if (!statusEl) return;
      statusEl.textContent = message;
      statusEl.dataset.kind = kind;
    }

    function clearForm() {
      if (barcodeInput) barcodeInput.value = "";
      if (descriptionInput) descriptionInput.value = "";
      barcodeInput?.focus();
    }

    clearButton?.addEventListener("click", () => {
      clearForm();
      setStatus("Ready for the next scan.");
    });

    form?.addEventListener("submit", async (event) => {
      event.preventDefault();
      setStatus("Saving item...");
      if (submitButton) submitButton.disabled = true;

      try {
        const response = await fetch("/api/inventory", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Accept: "application/json",
          },
          body: JSON.stringify({
            barcode: barcodeInput?.value || "",
            description: descriptionInput?.value || "",
          }),
        });

        const payload = await response.json();

        if (!response.ok) {
          throw new Error(payload.error || "Unable to save item.");
        }

        clearForm();
        setStatus(`Saved ${payload.item.barcode}.`, "success");
        await loadItems();
      } catch (error) {
        setStatus(
          error instanceof Error ? error.message : "Unable to save item.",
          "error",
        );
      } finally {
        if (submitButton) submitButton.disabled = false;
      }
    });

    loadItems();
    window.setInterval(loadItems, 5000);
    window.setTimeout(() => barcodeInput?.focus(), 50);
  </script>
</BaseLayout>
