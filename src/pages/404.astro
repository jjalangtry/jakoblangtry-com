---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../../styles.css";
---

<BaseLayout
  title="404 - Page Not Found | Jakob Langtry"
  description="The page you requested could not be found."
>
  <div class="page-container">
    <div
      class="terminal"
      style="display:flex;align-items:center;justify-content:center;flex-direction:column;gap:16px;"
    >
      <pre
        class="ascii-art"
        style="text-align:center;">
 ██╗  ██╗ ██████╗ ██╗  ██╗
 ██║  ██║██╔═══██╗██║  ██║
 ███████║██║   ██║███████║
 ╚════██║██║   ██║╚════██║
      ██║╚██████╔╝     ██║
      ╚═╝ ╚═════╝      ╚═╝</pre>
      <div class="info-text" style="text-align:center;">
        Page not found. The path you requested doesn't exist.
      </div>
      <div style="display:flex;gap:12px;">
        <a href="/" class="quick-action-link" style="text-decoration:none;">
          ← Go Home
        </a>
        <a
          href="/#projects"
          class="quick-action-link"
          style="text-decoration:none;"
        >
          View Projects
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
