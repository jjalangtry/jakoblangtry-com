---
const pageStats = {
  linesOfCode: 1025,
  aiMinutes: 22,
  humanHours: 7.5,
};
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"
    />
    <meta name="theme-color" content="#03110a" />
    <title>For Nathan | AI Build Report</title>
    <style>
      @import url("https://fonts.googleapis.com/css2?family=Major+Mono+Display&family=IBM+Plex+Mono:wght@400;500;700&display=swap");

      :root {
        --bg: #03110a;
        --bg-2: #041a0d;
        --panel: rgba(3, 22, 10, 0.72);
        --panel-strong: rgba(8, 34, 15, 0.9);
        --line: rgba(101, 255, 153, 0.22);
        --line-strong: rgba(101, 255, 153, 0.5);
        --text: #d6ffe6;
        --muted: rgba(196, 255, 215, 0.68);
        --green: #65ff99;
        --green-hot: #b8ffcb;
        --green-deep: #1fbd57;
        --amber: #d8ff7a;
        --shadow: 0 0 18px rgba(101, 255, 153, 0.18);
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html,
      body {
        min-height: 100%;
        background:
          radial-gradient(
            circle at top,
            rgba(27, 95, 50, 0.22),
            transparent 38%
          ),
          linear-gradient(180deg, #06160d 0%, #030b06 48%, #020805 100%);
        color: var(--text);
      }

      body {
        overflow-x: hidden;
        font-family: "IBM Plex Mono", monospace;
      }

      canvas,
      .screen-fx,
      .screen-fx::before,
      .screen-fx::after {
        pointer-events: none;
      }

      #matrix-mask,
      .screen-fx {
        position: fixed;
        inset: 0;
      }

      #matrix-mask {
        z-index: 0;
        opacity: 0.9;
      }

      .screen-fx {
        z-index: 3;
        background: linear-gradient(
          180deg,
          rgba(255, 255, 255, 0.02) 0%,
          rgba(255, 255, 255, 0) 25%,
          rgba(255, 255, 255, 0.02) 50%,
          rgba(255, 255, 255, 0) 75%,
          rgba(255, 255, 255, 0.03) 100%
        );
        mix-blend-mode: screen;
      }

      .screen-fx::before,
      .screen-fx::after {
        content: "";
        position: absolute;
        inset: 0;
      }

      .screen-fx::before {
        background: repeating-linear-gradient(
          180deg,
          rgba(0, 0, 0, 0) 0,
          rgba(0, 0, 0, 0) 3px,
          rgba(123, 255, 164, 0.05) 4px
        );
        opacity: 0.33;
      }

      .screen-fx::after {
        animation: pulse 6s ease-in-out infinite;
        background:
          radial-gradient(
            circle at 50% 0%,
            rgba(151, 255, 182, 0.09),
            transparent 34%
          ),
          radial-gradient(
            circle at 80% 20%,
            rgba(101, 255, 153, 0.08),
            transparent 24%
          );
      }

      .page {
        position: relative;
        z-index: 2;
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 32px 20px 64px;
      }

      .hud {
        position: relative;
        width: min(1180px, 100%);
        border: 1px solid var(--line);
        background:
          linear-gradient(180deg, rgba(2, 15, 7, 0.83), rgba(3, 11, 7, 0.88)),
          rgba(0, 0, 0, 0.25);
        box-shadow:
          0 0 0 1px rgba(101, 255, 153, 0.08) inset,
          0 24px 90px rgba(0, 0, 0, 0.5),
          0 0 90px rgba(27, 130, 65, 0.14);
        backdrop-filter: blur(14px);
        overflow: hidden;
      }

      .hud::before {
        content: "";
        position: absolute;
        inset: 0;
        background:
          linear-gradient(
            90deg,
            transparent,
            rgba(101, 255, 153, 0.06),
            transparent
          ),
          linear-gradient(180deg, rgba(101, 255, 153, 0.05), transparent 18%);
        transform: translateX(-100%);
        animation: sweep 7s linear infinite;
      }

      .topbar {
        position: relative;
        z-index: 1;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 12px 18px;
        border-bottom: 1px solid var(--line);
        background: rgba(11, 35, 18, 0.72);
        text-transform: uppercase;
        letter-spacing: 0.18em;
        font-size: 11px;
      }

      .topbar__group {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
      }

      .dot {
        width: 10px;
        height: 10px;
        border-radius: 999px;
        background: var(--green);
        box-shadow: 0 0 14px rgba(101, 255, 153, 0.8);
      }

      .content {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
      }

      .hero,
      .rail {
        padding: 28px;
      }

      .hero {
        border-right: 1px solid var(--line);
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 18px;
        padding: 8px 12px;
        border: 1px solid var(--line);
        background: rgba(6, 29, 14, 0.58);
        color: var(--green-hot);
        font-size: 12px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        box-shadow: var(--shadow);
      }

      h1 {
        font-family: "Major Mono Display", monospace;
        font-size: clamp(2.2rem, 4vw, 4.9rem);
        line-height: 1.06;
        letter-spacing: 0.08em;
        color: var(--green-hot);
        text-shadow:
          0 0 18px rgba(101, 255, 153, 0.2),
          0 0 50px rgba(101, 255, 153, 0.12);
      }

      .lede {
        max-width: 56ch;
        margin-top: 22px;
        color: var(--muted);
        font-size: clamp(1rem, 1.45vw, 1.15rem);
        line-height: 1.75;
      }

      .compare {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 14px;
        margin-top: 28px;
      }

      .metric {
        position: relative;
        padding: 18px;
        border: 1px solid var(--line);
        background: linear-gradient(
          180deg,
          rgba(8, 34, 15, 0.86),
          rgba(4, 17, 9, 0.9)
        );
        min-height: 146px;
        transition:
          transform 220ms ease,
          border-color 220ms ease,
          box-shadow 220ms ease;
      }

      .metric:hover {
        transform: translateY(-4px);
        border-color: var(--line-strong);
        box-shadow:
          0 16px 36px rgba(0, 0, 0, 0.28),
          var(--shadow);
      }

      .metric::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(
          135deg,
          rgba(184, 255, 203, 0.12),
          transparent 35%,
          transparent 60%,
          rgba(101, 255, 153, 0.08)
        );
        opacity: 0.9;
      }

      .metric__label,
      .metric__sub,
      .metric__value {
        position: relative;
        z-index: 1;
      }

      .metric__label {
        color: var(--muted);
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.18em;
      }

      .metric__value {
        margin-top: 14px;
        color: var(--green-hot);
        font-size: clamp(2rem, 4vw, 3.4rem);
        line-height: 1;
      }

      .metric__sub {
        margin-top: 12px;
        color: var(--muted);
        font-size: 0.92rem;
        line-height: 1.6;
      }

      .ticker {
        display: flex;
        gap: 26px;
        margin-top: 26px;
        padding: 12px 0;
        overflow: hidden;
        border-top: 1px solid var(--line);
        border-bottom: 1px solid var(--line);
        color: var(--amber);
        text-transform: uppercase;
        letter-spacing: 0.18em;
        font-size: 12px;
        white-space: nowrap;
      }

      .ticker__track {
        display: flex;
        gap: 26px;
        min-width: max-content;
        animation: marquee 18s linear infinite;
      }

      .stack {
        display: grid;
        gap: 14px;
        margin-top: 22px;
      }

      .card {
        position: relative;
        border: 1px solid var(--line);
        background: var(--panel);
        padding: 18px;
        overflow: hidden;
      }

      .card::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(
          180deg,
          rgba(184, 255, 203, 0.05),
          rgba(184, 255, 203, 0)
        );
      }

      .card h2,
      .card p,
      .card ul,
      .card .mini-grid {
        position: relative;
        z-index: 1;
      }

      .card h2 {
        margin-bottom: 12px;
        color: var(--green-hot);
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 0.2em;
      }

      .card p,
      .card li {
        color: var(--muted);
        line-height: 1.72;
        font-size: 0.95rem;
      }

      .card ul {
        list-style: none;
        display: grid;
        gap: 10px;
      }

      .card li::before {
        content: ">";
        margin-right: 10px;
        color: var(--green);
      }

      .mini-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px;
      }

      .mini-cell {
        padding: 14px;
        border: 1px solid rgba(101, 255, 153, 0.14);
        background: rgba(6, 22, 11, 0.55);
      }

      .mini-cell strong {
        display: block;
        color: var(--green-hot);
        font-size: 1.25rem;
        margin-bottom: 8px;
      }

      .rail {
        display: grid;
        gap: 14px;
        background: linear-gradient(
          180deg,
          rgba(3, 16, 8, 0.75),
          rgba(3, 11, 7, 0.95)
        );
      }

      .rail-card {
        border: 1px solid var(--line);
        background: var(--panel-strong);
        padding: 18px;
      }

      .rail-card h3 {
        color: var(--green-hot);
        margin-bottom: 12px;
        font-size: 12px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
      }

      .rail-card p {
        color: var(--muted);
        line-height: 1.7;
        font-size: 0.92rem;
      }

      .big-stat {
        display: grid;
        gap: 6px;
        padding: 18px;
        border: 1px solid var(--line);
        background:
          radial-gradient(
            circle at top right,
            rgba(101, 255, 153, 0.12),
            transparent 42%
          ),
          rgba(5, 21, 11, 0.88);
      }

      .big-stat span {
        color: var(--muted);
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.18em;
      }

      .big-stat strong {
        color: var(--green-hot);
        font-size: clamp(2rem, 4vw, 3rem);
        text-shadow: 0 0 20px rgba(101, 255, 153, 0.2);
      }

      .bar-chart {
        display: grid;
        gap: 12px;
      }

      .bar {
        display: grid;
        gap: 8px;
      }

      .bar__meta {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        color: var(--muted);
        font-size: 0.84rem;
      }

      .bar__track {
        position: relative;
        height: 12px;
        border: 1px solid var(--line);
        background: rgba(6, 18, 10, 0.7);
        overflow: hidden;
      }

      .bar__fill {
        position: absolute;
        inset: 0 auto 0 0;
        width: var(--fill, 50%);
        background: linear-gradient(90deg, var(--green-deep), var(--green-hot));
        box-shadow: 0 0 22px rgba(101, 255, 153, 0.3);
        transform-origin: left;
        animation: grow 1.4s cubic-bezier(0.22, 1, 0.36, 1) both;
      }

      .footnote {
        padding: 16px 18px 20px;
        border-top: 1px solid var(--line);
        color: rgba(196, 255, 215, 0.56);
        font-size: 0.8rem;
        line-height: 1.6;
      }

      .scanline {
        position: fixed;
        left: 0;
        right: 0;
        height: 120px;
        background: linear-gradient(
          180deg,
          rgba(101, 255, 153, 0) 0%,
          rgba(101, 255, 153, 0.08) 50%,
          rgba(101, 255, 153, 0) 100%
        );
        mix-blend-mode: screen;
        animation: scan 8s linear infinite;
        z-index: 2;
        pointer-events: none;
      }

      .corner {
        position: absolute;
        width: 22px;
        height: 22px;
        border-color: var(--line-strong);
      }

      .corner--tl {
        top: 10px;
        left: 10px;
        border-top: 1px solid;
        border-left: 1px solid;
      }

      .corner--tr {
        top: 10px;
        right: 10px;
        border-top: 1px solid;
        border-right: 1px solid;
      }

      .corner--bl {
        bottom: 10px;
        left: 10px;
        border-bottom: 1px solid;
        border-left: 1px solid;
      }

      .corner--br {
        right: 10px;
        bottom: 10px;
        border-right: 1px solid;
        border-bottom: 1px solid;
      }

      @keyframes sweep {
        to {
          transform: translateX(100%);
        }
      }

      @keyframes pulse {
        0%,
        100% {
          opacity: 0.65;
        }
        50% {
          opacity: 1;
        }
      }

      @keyframes marquee {
        from {
          transform: translateX(0);
        }
        to {
          transform: translateX(-50%);
        }
      }

      @keyframes grow {
        from {
          transform: scaleX(0);
        }
      }

      @keyframes scan {
        from {
          transform: translateY(-140px);
        }
        to {
          transform: translateY(calc(100vh + 140px));
        }
      }

      @media (max-width: 960px) {
        .content {
          grid-template-columns: 1fr;
        }

        .hero {
          border-right: 0;
          border-bottom: 1px solid var(--line);
        }
      }

      @media (max-width: 720px) {
        .page {
          padding: 16px 12px 40px;
        }

        .hero,
        .rail {
          padding: 18px;
        }

        .compare,
        .mini-grid {
          grid-template-columns: 1fr;
        }

        .ticker {
          font-size: 11px;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        *,
        *::before,
        *::after {
          animation-duration: 0.001ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.001ms !important;
          scroll-behavior: auto !important;
        }
      }
    </style>
  </head>
  <body>
    <canvas id="matrix-mask"></canvas>
    <div class="screen-fx"></div>
    <div class="scanline"></div>

    <main class="page">
      <section class="hud">
        <span class="corner corner--tl"></span>
        <span class="corner corner--tr"></span>
        <span class="corner corner--bl"></span>
        <span class="corner corner--br"></span>

        <div class="topbar">
          <div class="topbar__group">
            <span class="dot"></span>
            <span>ptui // ai build report // nathan edition</span>
          </div>
          <div class="topbar__group">
            <span>route: /fornathan</span>
            <span>mode: hyper-styled</span>
          </div>
        </div>

        <div class="content">
          <section class="hero">
            <div class="eyebrow">
              live proof that ai development compresses time
            </div>
            <h1>more build.<br />less waiting.</h1>
            <p class="lede">
              This page is a deliberately overbuilt little demo for Nathan: one
              AI-assisted page, custom layout, animated canvas background,
              responsive HUD, stylized stat cards, and narrative copy turned
              around in a single session instead of spending most of the day in
              design drift.
            </p>

            <div class="compare">
              <article class="metric">
                <div class="metric__label">Lines Written</div>
                <div class="metric__value" data-counter={pageStats.linesOfCode}>
                  0
                </div>
                <p class="metric__sub">
                  Exact line count for this route file, including styles,
                  markup, and animation logic.
                </p>
              </article>

              <article class="metric">
                <div class="metric__label">AI Time</div>
                <div
                  class="metric__value"
                  data-counter={pageStats.aiMinutes}
                  data-suffix="m"
                >
                  0
                </div>
                <p class="metric__sub">
                  Concept, implementation, polish, and integration done in one
                  pass.
                </p>
              </article>

              <article class="metric">
                <div class="metric__label">Human Estimate</div>
                <div
                  class="metric__value"
                  data-counter={pageStats.humanHours}
                  data-suffix="h"
                  data-decimals="1"
                >
                  0
                </div>
                <p class="metric__sub">
                  Rough estimate for hand-designing, animating, tweaking, and
                  shipping the same page manually.
                </p>
              </article>
            </div>

            <div class="ticker" aria-hidden="true">
              <div class="ticker__track">
                <span>ai accelerates prototypes</span>
                <span>copy + layout + animation in one loop</span>
                <span>less blank-canvas time</span>
                <span>faster iteration on weird ideas</span>
                <span>ai accelerates prototypes</span>
                <span>copy + layout + animation in one loop</span>
                <span>less blank-canvas time</span>
                <span>faster iteration on weird ideas</span>
              </div>
            </div>

            <div class="stack">
              <article class="card">
                <h2>Why this is useful</h2>
                <ul>
                  <li>
                    AI removes the cold-start tax of design, copy, and
                    scaffolding.
                  </li>
                  <li>
                    It makes experiments cheap enough to try the bold version
                    first.
                  </li>
                  <li>
                    It compresses implementation and revision into the same
                    loop.
                  </li>
                </ul>
              </article>

              <article class="card">
                <h2>What shipped here</h2>
                <div class="mini-grid">
                  <div class="mini-cell">
                    <strong>Canvas FX</strong>
                    Animated glyph field with a text-mask treatment inspired by `/fortree`.
                  </div>
                  <div class="mini-cell">
                    <strong>PTUI Skin</strong>
                    CRT scanlines, HUD corners, glowing bars, and terminal-green contrast.
                  </div>
                  <div class="mini-cell">
                    <strong>Responsive</strong>
                    Works as a dense dashboard on desktop and stacks cleanly on mobile.
                  </div>
                  <div class="mini-cell">
                    <strong>Live Stats</strong>
                    Animated counters make the “speed delta” visible instead of just
                    claimed.
                  </div>
                </div>
              </article>
            </div>
          </section>

          <aside class="rail">
            <section class="big-stat">
              <span>Compression Ratio</span>
              <strong>~20x faster</strong>
            </section>

            <section class="rail-card">
              <h3>Estimated Breakdown</h3>
              <div class="bar-chart">
                <div class="bar">
                  <div class="bar__meta">
                    <span>Human build loop</span>
                    <span>7.5h</span>
                  </div>
                  <div class="bar__track">
                    <div class="bar__fill" style="--fill: 100%;"></div>
                  </div>
                </div>
                <div class="bar">
                  <div class="bar__meta">
                    <span>AI-assisted build loop</span>
                    <span>22m</span>
                  </div>
                  <div class="bar__track">
                    <div class="bar__fill" style="--fill: 8%;"></div>
                  </div>
                </div>
              </div>
            </section>

            <section class="rail-card">
              <h3>Where the savings show up</h3>
              <p>
                The point is not “humans are slow.” The point is that
                high-friction parts of frontend work like first drafts,
                variations, filler copy, layout glue, and animation scaffolding
                stop eating the whole afternoon.
              </p>
            </section>

            <section class="rail-card">
              <h3>Why Nathan might care</h3>
              <p>
                If you already know what “good” looks like, AI makes getting to
                a strong first version dramatically faster. Taste still matters.
                Direction still matters. But the distance from idea to visible
                thing gets much shorter.
              </p>
            </section>
          </aside>
        </div>

        <div class="footnote">
          Stats shown here are intentionally framed as estimates, not universal
          laws. The exact line count is generated from this route file. The time
          comparison reflects the real build session for this page versus a
          reasonable manual estimate for comparable custom design and frontend
          work.
        </div>
      </section>
    </main>

    <script is:inline define:vars={{ pageStats }}>
      (function () {
        var prefersReducedMotion = window.matchMedia(
          "(prefers-reduced-motion: reduce)",
        ).matches;

        var counters = document.querySelectorAll("[data-counter]");
        counters.forEach(function (node, index) {
          var target = Number(node.getAttribute("data-counter")) || 0;
          var suffix = node.getAttribute("data-suffix") || "";
          var decimals = Number(node.getAttribute("data-decimals") || 0);
          var duration = prefersReducedMotion ? 0 : 900 + index * 240;
          var start = performance.now();

          function render(now) {
            var progress =
              duration === 0 ? 1 : Math.min((now - start) / duration, 1);
            var eased = 1 - Math.pow(1 - progress, 3);
            var value = target * eased;
            node.textContent = value.toFixed(decimals) + suffix;
            if (progress < 1) requestAnimationFrame(render);
          }

          requestAnimationFrame(render);
        });

        var canvas = document.getElementById("matrix-mask");
        var ctx = canvas.getContext("2d");
        var W = 0;
        var H = 0;
        var cellW = 10;
        var cellH = 18;
        var cols = 0;
        var rows = 0;
        var mask;
        var time = 0;
        var chars = " .:-=+*#%@01";
        var pointerBursts = [];

        function hash(x, y) {
          var n = (x | 0) * 374761393 + (y | 0) * 668265263;
          n = (n ^ (n >> 13)) * 1274126177;
          return ((n ^ (n >> 16)) >>> 0) / 4294967295;
        }

        function smooth(t) {
          return t * t * (3 - 2 * t);
        }

        function noise(x, y) {
          var ix = Math.floor(x);
          var iy = Math.floor(y);
          var fx = smooth(x - ix);
          var fy = smooth(y - iy);
          var a = hash(ix, iy);
          var b = hash(ix + 1, iy);
          var c = hash(ix, iy + 1);
          var d = hash(ix + 1, iy + 1);
          return a + (b - a) * fx + (c - a) * fy + (a - b - c + d) * fx * fy;
        }

        function fractal(x, y) {
          var total = 0;
          var amplitude = 0.5;
          for (var i = 0; i < 4; i++) {
            total += noise(x, y) * amplitude;
            x *= 2;
            y *= 2;
            amplitude *= 0.5;
          }
          return total;
        }

        function buildMask() {
          var scale = 4;
          var off = document.createElement("canvas");
          off.width = cols * scale;
          off.height = rows * scale;
          var ox = off.getContext("2d");
          ox.fillStyle = "#000";
          ox.fillRect(0, 0, off.width, off.height);
          ox.fillStyle = "#fff";
          ox.textAlign = "center";
          ox.textBaseline = "middle";

          var line1 = "FOR";
          var line2 = "NATHAN";
          var widthTarget = off.width * 0.72;
          var size1 = 12;
          var size2 = 12;

          do {
            size1 += 2;
            ox.font = "700 " + size1 + "px sans-serif";
          } while (ox.measureText(line1).width < widthTarget * 0.45);

          do {
            size2 += 2;
            ox.font = "900 " + size2 + "px sans-serif";
          } while (ox.measureText(line2).width < widthTarget);

          var gap = off.height * 0.04;
          var top = off.height * 0.24;

          ox.font = "700 " + size1 + "px sans-serif";
          ox.fillText(line1, off.width / 2, top);
          ox.font = "900 " + size2 + "px sans-serif";
          ox.fillText(line2, off.width / 2, top + size2 * 0.85 + gap);

          var pixels = ox.getImageData(0, 0, off.width, off.height).data;
          mask = new Uint8Array(cols * rows);

          for (var row = 0; row < rows; row++) {
            for (var col = 0; col < cols; col++) {
              var sum = 0;
              for (var dy = 0; dy < scale; dy++) {
                for (var dx = 0; dx < scale; dx++) {
                  var idx =
                    ((row * scale + dy) * off.width + (col * scale + dx)) * 4;
                  sum += pixels[idx];
                }
              }
              mask[row * cols + col] = sum / (scale * scale) > 55 ? 1 : 0;
            }
          }
        }

        function resize() {
          var dpr = window.devicePixelRatio || 1;
          W = window.innerWidth;
          H = window.innerHeight;
          canvas.width = W * dpr;
          canvas.height = H * dpr;
          canvas.style.width = W + "px";
          canvas.style.height = H + "px";
          ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

          ctx.font = '15px "IBM Plex Mono", monospace';
          cellW = Math.max(9, Math.ceil(ctx.measureText("M").width));
          cellH = 18;
          cols = Math.ceil(W / cellW);
          rows = Math.ceil(H / cellH);
          buildMask();
        }

        function spawnBurst(x, y) {
          for (var i = 0; i < 16; i++) {
            var angle = (Math.PI * 2 * i) / 16 + Math.random() * 0.25;
            var speed = 24 + Math.random() * 55;
            pointerBursts.push({
              x: x,
              y: y,
              vx: Math.cos(angle) * speed,
              vy: Math.sin(angle) * speed,
              life: 0,
              maxLife: 0.9 + Math.random() * 0.6,
            });
          }
        }

        function onPointer(event) {
          if (prefersReducedMotion) return;
          spawnBurst(event.clientX, event.clientY);
        }

        window.addEventListener("resize", resize);
        window.addEventListener("pointerdown", onPointer);
        resize();

        function frame(ts) {
          var dt = Math.min(0.1, (ts - time) / 1000 || 0.016);
          time = ts;
          var seconds = ts / 1000;

          ctx.clearRect(0, 0, W, H);
          ctx.fillStyle = "rgba(3, 10, 6, 0.18)";
          ctx.fillRect(0, 0, W, H);
          ctx.font = '15px "IBM Plex Mono", monospace';
          ctx.textBaseline = "top";

          for (var row = 0; row < rows; row++) {
            var y = row * cellH;
            for (var col = 0; col < cols; col++) {
              if (!mask[row * cols + col]) continue;
              var x = col * cellW;
              var v = fractal(
                col * 0.08 + seconds * 0.55,
                row * 0.08 + seconds * 0.12,
              );
              v += 0.24 * Math.sin(col * 0.06 + seconds * 2.4);
              v += 0.18 * Math.sin(row * 0.09 - seconds * 1.4);
              v = Math.max(0, Math.min(1, (v + 0.15) / 1.3));
              var ch = chars[(v * (chars.length - 1)) | 0];
              if (ch === " ") continue;
              var alpha = 0.24 + v * 0.76;
              ctx.fillStyle = "rgba(101,255,153," + alpha.toFixed(3) + ")";
              ctx.fillText(ch, x, y);
            }
          }

          for (var i = pointerBursts.length - 1; i >= 0; i--) {
            var burst = pointerBursts[i];
            burst.life += dt;
            burst.x += burst.vx * dt;
            burst.y += burst.vy * dt;
            burst.vx *= 0.985;
            burst.vy *= 0.985;

            if (burst.life >= burst.maxLife) {
              pointerBursts.splice(i, 1);
              continue;
            }

            var opacity = 1 - burst.life / burst.maxLife;
            ctx.fillStyle = "rgba(216,255,122," + opacity.toFixed(3) + ")";
            ctx.fillRect(burst.x, burst.y, 2, 2);
          }

          requestAnimationFrame(frame);
        }

        requestAnimationFrame(frame);
      })();
    </script>
  </body>
</html>
